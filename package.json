{
  "name": "browser-tools-mcp-monorepo",
  "version": "1.2.0",
  "private": true,
  "description": "Browser Tools MCP - Monorepo",
  "scripts": {
    "dev": "cd browser-tools-mcp && npm run dev",
    "dev:server": "cd browser-tools-server && npm start",
    "build": "cd browser-tools-mcp && npm run build && cd ../browser-tools-server && npm run build",
    "start": "cd browser-tools-mcp && npm start"
  },
  "workspaces": [
    "browser-tools-mcp",
    "browser-tools-server"
  ]
}
